[{"D:\\DEV_JS\\React\\gitsearch\\src\\App.tsx":"1","D:\\DEV_JS\\React\\gitsearch\\src\\index.tsx":"2","D:\\DEV_JS\\React\\gitsearch\\src\\components\\searchScreen.tsx":"3","D:\\DEV_JS\\React\\gitsearch\\src\\components\\userScreen.tsx":"4","D:\\DEV_JS\\React\\gitsearch\\src\\components\\RepositoryComp.tsx":"5","D:\\DEV_JS\\React\\gitsearch\\src\\components\\usersComponent.tsx":"6","D:\\DEV_JS\\React\\gitsearch\\src\\components\\RepositoryScreen.tsx":"7","D:\\DEV_JS\\React\\gitsearch\\src\\components\\repositoryScreen.tsx":"8"},{"size":746,"mtime":1606926673090,"results":"9","hashOfConfig":"10"},{"size":682,"mtime":1606929288119,"results":"11","hashOfConfig":"10"},{"size":3390,"mtime":1606929147680,"results":"12","hashOfConfig":"10"},{"size":1712,"mtime":1606932725903,"results":"13","hashOfConfig":"10"},{"size":1631,"mtime":1606932824521,"results":"14","hashOfConfig":"10"},{"size":909,"mtime":1606932782594,"results":"15","hashOfConfig":"10"},{"size":2632,"mtime":1606856130141,"results":"16","hashOfConfig":"10"},{"size":3393,"mtime":1606944377556,"results":"17","hashOfConfig":"10"},{"filePath":"18","messages":"19","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},"1ac1qv6",{"filePath":"20","messages":"21","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"22","messages":"23","errorCount":0,"warningCount":2,"fixableErrorCount":0,"fixableWarningCount":0,"source":"24"},{"filePath":"25","messages":"26","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"27","messages":"28","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"29","messages":"30","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"31","messages":"32","errorCount":0,"warningCount":2,"fixableErrorCount":0,"fixableWarningCount":0,"source":null},{"filePath":"33","messages":"34","errorCount":0,"warningCount":2,"fixableErrorCount":0,"fixableWarningCount":0,"source":"35"},"D:\\DEV_JS\\React\\gitsearch\\src\\App.tsx",[],"D:\\DEV_JS\\React\\gitsearch\\src\\index.tsx",[],"D:\\DEV_JS\\React\\gitsearch\\src\\components\\searchScreen.tsx",["36","37"],"import React, { useEffect, useState, FC } from 'react';\r\nimport { RepoData, UserData } from '../interfaces';\r\nimport { ReppositoriesList } from './RepositoryComp';\r\nimport { UsersList } from './usersComponent';\r\nimport '../styles/searchScreen.css';\r\n\r\n\r\nexport interface SearchScreenProps { }\r\n\r\nexport interface SearchScreenState {\r\n    fetchData: RepoData[] | UserData[],\r\n    mode: string,\r\n    queryString: string,\r\n}\r\n\r\nclass SearchScreen extends React.Component<SearchScreenProps, SearchScreenState> {\r\n    state: SearchScreenState = {\r\n        mode: 'repositories',\r\n        fetchData: [],\r\n        queryString: ''\r\n    }\r\n\r\n    handleSearch = async (queryString: string, mode?: string) => {\r\n        queryString = queryString.split(' ').join('+')\r\n        mode = (mode || this.state.mode)\r\n\r\n        let fetchData = await (await fetch('https://api.github.com/search/' + mode + '?q=' + queryString + '&sort=stars')).json()\r\n\r\n        this.setState({\r\n            queryString,\r\n            mode,\r\n            fetchData: fetchData.items ? fetchData.items : []\r\n        })\r\n    }\r\n\r\n    changeSearchMode = (mode: string) => {\r\n        const { queryString } = this.state\r\n        if (queryString) this.handleSearch(queryString, mode)\r\n        else this.setState({ mode: mode })\r\n    }\r\n\r\n    render() {\r\n        return (<>\r\n            <div className='search-area'>\r\n                <SearchBar handleSearch={this.handleSearch}></SearchBar>\r\n            </div>\r\n            <div className='result-area'>\r\n                <SearchModesList changeSearchMode={this.changeSearchMode}></SearchModesList>\r\n                {\r\n                    this.state.mode === 'users' ?\r\n                        <UsersList users={this.state.fetchData as UserData[]}></UsersList> :\r\n                        <ReppositoriesList repos={this.state.fetchData as RepoData[]}></ReppositoriesList>\r\n                }\r\n            </div>\r\n        </>);\r\n    }\r\n}\r\n\r\n\r\ninterface SearchBarProps { handleSearch: any }\r\nfunction SearchBar(props: SearchBarProps) {\r\n    const [queryString, setSearchValue] = useState('')\r\n\r\n    return (<>\r\n        <div className=\"searchbar\">\r\n            <h1 className='searchbar-title'>Search gitHub uers and repositories</h1>\r\n            <input type=\"text\" onChange={(e) => setSearchValue(e.target.value)} className=\"searchbarInput\" />\r\n            <button type=\"button\" onClick={() => props.handleSearch(queryString)} className=\"btn btn-primary searchbarBtn\">Search</button>\r\n        </div>\r\n    </>);\r\n}\r\n\r\n\r\ninterface SearchModeProps { changeSearchMode: any }\r\nfunction SearchModesList(props: SearchModeProps) {\r\n    const [selectedSearchMode, setselectedSearchMode] = useState('repositories')\r\n\r\n    useEffect(() => {\r\n        props.changeSearchMode(selectedSearchMode)\r\n    }, [selectedSearchMode]);\r\n\r\n    return (<>\r\n        <ul className=\"list-group list-group-horizontal resultlist\">\r\n            <li className={`\r\n                list-group-item\r\n                ${selectedSearchMode === 'repositories' ? 'active' : ''}\r\n            `} onClick={() => setselectedSearchMode('repositories')}>Repositories</li>\r\n            <li className={`\r\n                list-group-item\r\n                ${selectedSearchMode === 'users' ? 'active' : ''}\r\n            `} onClick={() => setselectedSearchMode('users')}>Users</li>\r\n        </ul>\r\n    </>)\r\n}\r\n\r\n\r\nexport default SearchScreen;\r\n","D:\\DEV_JS\\React\\gitsearch\\src\\components\\userScreen.tsx",[],"D:\\DEV_JS\\React\\gitsearch\\src\\components\\RepositoryComp.tsx",[],"D:\\DEV_JS\\React\\gitsearch\\src\\components\\usersComponent.tsx",[],"D:\\DEV_JS\\React\\gitsearch\\src\\components\\RepositoryScreen.tsx",["38","39"],"D:\\DEV_JS\\React\\gitsearch\\src\\components\\repositoryScreen.tsx",["40","41"],"import React, { FC } from 'react';\r\nimport { match } from 'react-router-dom';\r\nimport { RepoData, UserData } from '../interfaces';\r\nimport '../styles/repositoryScreen.css'\r\nimport Axios from 'axios';\r\nimport { RepoitoryProps } from '../App';\r\n\r\nexport interface RepositoryScreenProps {\r\n    match: match<RepoitoryProps>,\r\n    location: any\r\n}\r\n\r\nexport interface RepositoryScreenState {\r\n    repository?: RepoData,\r\n    repositoryCommits?: any[],\r\n}\r\n\r\nclass RepositoryScreen extends React.Component<RepositoryScreenProps, RepositoryScreenState> {\r\n    state: RepositoryScreenState = {}\r\n\r\n    componentDidMount() {\r\n        Axios.get(this.props.location.state)\r\n            .then(res => {\r\n                const repository: RepoData = res.data\r\n                let commitsurl = repository.commits_url.split('commits')\r\n                commitsurl.pop()\r\n                return Promise.all([repository, Axios.get(commitsurl.join('') + 'commits')])\r\n            })\r\n            .then(([repository, repos]) => {\r\n                this.setState({ repository, repositoryCommits: repos.data })\r\n            })\r\n            .catch(console.log)\r\n    }\r\n\r\n    render() {\r\n        const { repository, repositoryCommits } = this.state\r\n        if (!repository) return <h1 className='not-found'> Repository not found..</h1>\r\n\r\n        let commits = repositoryCommits ? repositoryCommits.map(commit => <Commit key={commit.sha} commit={commit.commit}></Commit>) : []\r\n\r\n        return (\r\n            <div className=\"repository-box\">\r\n                <div className=\"userbox\">\r\n                    <h1>\r\n                        <a target='blank' href={repository.owner.html_url}>\r\n                            <i className=\"demo-icon icon-user\"></i>\r\n                            {repository.owner.login}\r\n                        </a>\r\n                        <a target='blank' href={repository.html_url}>\r\n                            <i className=\"demo-icon icon-bookmark\"></i>\r\n                            {repository.name}\r\n                        </a>\r\n                    </h1>\r\n                    <p className='repository-description'>\r\n                        <span className=\"title\">about\r\n                        <i className=\"demo-icon icon-search\"></i>\r\n                        </span>\r\n                        {repository.description}\r\n                    </p>\r\n                </div>\r\n                <div className=\"commits\">\r\n                    <p className=\"title\">commits<i className=\"demo-icon icon-flow-branch\"></i> </p>\r\n                    {commits}\r\n                </div>\r\n            </div>\r\n        );\r\n    }\r\n}\r\n\r\n\r\ninterface Commit {\r\n    message: string,\r\n    committer: {\r\n        name: string,\r\n        email: string,\r\n        date: string,\r\n    }\r\n}\r\n\r\nexport const Commit: FC<{ commit: Commit }> = ({ commit }) => {\r\n    let date = new Date(commit.committer.date).toLocaleDateString()\r\n    return (<div className='commit'>\r\n        <h1 className='committer-name'><span className=\"label\">Commiter:</span> {commit.committer.name}</h1>\r\n        <p className='committer-email'><span className=\"label\">email:</span> {commit.committer.email}</p>\r\n        <p className=\"commit-message\"><span className=\"label\">message:</span> {commit.message}</p>\r\n        <p className=\"commit-date\"><span className=\"label\">date:</span> {date}</p>\r\n    </div>)\r\n}\r\n\r\nexport default RepositoryScreen;\r\n",{"ruleId":"42","severity":1,"message":"43","line":1,"column":38,"nodeType":"44","messageId":"45","endLine":1,"endColumn":40},{"ruleId":"46","severity":1,"message":"47","line":80,"column":8,"nodeType":"48","endLine":80,"endColumn":28,"suggestions":"49"},{"ruleId":"42","severity":1,"message":"50","line":3,"column":20,"nodeType":"44","messageId":"45","endLine":3,"endColumn":28},{"ruleId":"51","severity":1,"message":"52","line":66,"column":14,"nodeType":"44","messageId":"53","endLine":66,"endColumn":44},{"ruleId":"42","severity":1,"message":"50","line":3,"column":20,"nodeType":"44","messageId":"45","endLine":3,"endColumn":28},{"ruleId":"51","severity":1,"message":"52","line":80,"column":14,"nodeType":"44","messageId":"53","endLine":80,"endColumn":44},"@typescript-eslint/no-unused-vars","'FC' is defined but never used.","Identifier","unusedVar","react-hooks/exhaustive-deps","React Hook useEffect has a missing dependency: 'props'. Either include it or remove the dependency array. However, 'props' will change when *any* prop changes, so the preferred fix is to destructure the 'props' object outside of the useEffect call and refer to those specific props inside useEffect.","ArrayExpression",["54"],"'UserData' is defined but never used.","@typescript-eslint/no-redeclare","'Commit' is already defined.","redeclared",{"desc":"55","fix":"56"},"Update the dependencies array to be: [props, selectedSearchMode]",{"range":"57","text":"58"},[2787,2807],"[props, selectedSearchMode]"]
[{"D:\\DEV_JS\\React\\gitsearch\\src\\App.tsx":"1","D:\\DEV_JS\\React\\gitsearch\\src\\index.tsx":"2","D:\\DEV_JS\\React\\gitsearch\\src\\components\\searchScreen.tsx":"3","D:\\DEV_JS\\React\\gitsearch\\src\\components\\userScreen.tsx":"4","D:\\DEV_JS\\React\\gitsearch\\src\\components\\RepositoryScreen.tsx":"5","D:\\DEV_JS\\React\\gitsearch\\src\\components\\repositoryScreen.tsx":"6","D:\\DEV_JS\\React\\gitsearch\\src\\components\\repositoryComponents.tsx":"7"},{"size":855,"mtime":1606996835028,"results":"8","hashOfConfig":"9"},{"size":682,"mtime":1606998733571,"results":"10","hashOfConfig":"9"},{"size":8639,"mtime":1607026970220,"results":"11","hashOfConfig":"9"},{"size":1712,"mtime":1606932725903,"results":"12","hashOfConfig":"9"},{"size":2632,"mtime":1606856130141,"results":"13","hashOfConfig":"9"},{"size":3383,"mtime":1606944838314,"results":"14","hashOfConfig":"9"},{"size":1905,"mtime":1607027045230,"results":"15","hashOfConfig":"9"},{"filePath":"16","messages":"17","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},"1ac1qv6",{"filePath":"18","messages":"19","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"20"},{"filePath":"21","messages":"22","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"23","messages":"24","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"20"},{"filePath":"25","messages":"26","errorCount":0,"warningCount":2,"fixableErrorCount":0,"fixableWarningCount":0,"source":null},{"filePath":"27","messages":"28","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"29"},{"filePath":"30","messages":"31","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},"D:\\DEV_JS\\React\\gitsearch\\src\\App.tsx",[],"D:\\DEV_JS\\React\\gitsearch\\src\\index.tsx",[],["32","33"],"D:\\DEV_JS\\React\\gitsearch\\src\\components\\searchScreen.tsx",[],"D:\\DEV_JS\\React\\gitsearch\\src\\components\\userScreen.tsx",[],"D:\\DEV_JS\\React\\gitsearch\\src\\components\\RepositoryScreen.tsx",["34","35"],"D:\\DEV_JS\\React\\gitsearch\\src\\components\\repositoryScreen.tsx",["36"],"import React, { FC } from 'react';\r\nimport { match } from 'react-router-dom';\r\nimport { RepoData } from '../interfaces';\r\nimport '../styles/repositoryScreen.css'\r\nimport Axios from 'axios';\r\nimport { RepoitoryProps } from '../App';\r\n\r\nexport interface RepositoryScreenProps {\r\n    match: match<RepoitoryProps>,\r\n    location: any\r\n}\r\n\r\nexport interface RepositoryScreenState {\r\n    repository?: RepoData,\r\n    repositoryCommits?: any[],\r\n}\r\n\r\nclass RepositoryScreen extends React.Component<RepositoryScreenProps, RepositoryScreenState> {\r\n    state: RepositoryScreenState = {}\r\n\r\n    componentDidMount() {\r\n        Axios.get(this.props.location.state)\r\n            .then(res => {\r\n                const repository: RepoData = res.data\r\n                let commitsurl = repository.commits_url.split('commits')\r\n                commitsurl.pop()\r\n                return Promise.all([repository, Axios.get(commitsurl.join('') + 'commits')])\r\n            })\r\n            .then(([repository, repos]) => {\r\n                this.setState({ repository, repositoryCommits: repos.data })\r\n            })\r\n            .catch(console.log)\r\n    }\r\n\r\n    render() {\r\n        const { repository, repositoryCommits } = this.state\r\n        if (!repository) return <h1 className='not-found'> Repository not found..</h1>\r\n\r\n        let commits = repositoryCommits ? repositoryCommits.map(commit => <Commit key={commit.sha} commit={commit.commit}></Commit>) : []\r\n\r\n        return (\r\n            <div className=\"repository-box\">\r\n                <div className=\"userbox\">\r\n                    <h1>\r\n                        <a target='blank' href={repository.owner.html_url}>\r\n                            <i className=\"demo-icon icon-user\"></i>\r\n                            {repository.owner.login}\r\n                        </a>\r\n                        <a target='blank' href={repository.html_url}>\r\n                            <i className=\"demo-icon icon-bookmark\"></i>\r\n                            {repository.name}\r\n                        </a>\r\n                    </h1>\r\n                    <p className='repository-description'>\r\n                        <span className=\"title\">about\r\n                        <i className=\"demo-icon icon-search\"></i>\r\n                        </span>\r\n                        {repository.description}\r\n                    </p>\r\n                </div>\r\n                <div className=\"commits\">\r\n                    <p className=\"title\">commits<i className=\"demo-icon icon-flow-branch\"></i> </p>\r\n                    {commits}\r\n                </div>\r\n            </div>\r\n        );\r\n    }\r\n}\r\n\r\n\r\ninterface Commit {\r\n    message: string,\r\n    committer: {\r\n        name: string,\r\n        email: string,\r\n        date: string,\r\n    }\r\n}\r\n\r\nexport const Commit: FC<{ commit: Commit }> = ({ commit }) => {\r\n    let date = new Date(commit.committer.date).toLocaleDateString()\r\n    return (<div className='commit'>\r\n        <h1 className='committer-name'><span className=\"label\">Commiter:</span> {commit.committer.name}</h1>\r\n        <p className='committer-email'><span className=\"label\">email:</span> {commit.committer.email}</p>\r\n        <p className=\"commit-message\"><span className=\"label\">message:</span> {commit.message}</p>\r\n        <p className=\"commit-date\"><span className=\"label\">date:</span> {date}</p>\r\n    </div>)\r\n}\r\n\r\nexport default RepositoryScreen;\r\n","D:\\DEV_JS\\React\\gitsearch\\src\\components\\repositoryComponents.tsx",[],{"ruleId":"37","replacedBy":"38"},{"ruleId":"39","replacedBy":"40"},{"ruleId":"41","severity":1,"message":"42","line":3,"column":20,"nodeType":"43","messageId":"44","endLine":3,"endColumn":28},{"ruleId":"45","severity":1,"message":"46","line":66,"column":14,"nodeType":"43","messageId":"47","endLine":66,"endColumn":44},{"ruleId":"45","severity":1,"message":"46","line":80,"column":14,"nodeType":"43","messageId":"47","endLine":80,"endColumn":44},"no-native-reassign",["48"],"no-negated-in-lhs",["49"],"@typescript-eslint/no-unused-vars","'UserData' is defined but never used.","Identifier","unusedVar","@typescript-eslint/no-redeclare","'Commit' is already defined.","redeclared","no-global-assign","no-unsafe-negation"]
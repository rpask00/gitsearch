ingCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"36"},"D:\\DEV_JS\\React\\gitsearch\\src\\App.tsx",[],"D:\\DEV_JS\\React\\gitsearch\\src\\index.tsx",[],"D:\\DEV_JS\\React\\gitsearch\\src\\components\\searchScreen.tsx",["37","38","39","40"],"import React, { useEffect, useState, FC, ReducerStateWithoutAction } from 'react';\r\nimport { RepoData, UserData } from '../interfaces';\r\nimport { ReppositoriesList } from './RepositoryComp';\r\nimport { UsersList } from './usersComponent';\r\nimport '../styles/searchScreen.css';\r\nlet qstirngSave = ''\r\n\r\nexport interface SearchScreenProps {\r\n    qstring: string,\r\n    changeqstring: any\r\n}\r\n\r\n\r\nexport interface SearchScreenState {\r\n    fetchData: RepoData[] | UserData[],\r\n    searchMode: string,\r\n    sortMode: string,\r\n    queryString: string,\r\n}\r\n\r\nclass SearchScreen extends React.Component<SearchScreenProps, SearchScreenState> {\r\n    state: SearchScreenState = {\r\n        sortMode: 'desc',\r\n        searchMode: 'repositories',\r\n        fetchData: [],\r\n        queryString: ''\r\n    }\r\n\r\n    componentDidMount() {\r\n        const { qstring } = this.props\r\n        qstirngSave = qstring\r\n        if (qstring) this.handleSearch(qstring)\r\n    }\r\n\r\n    handleSearch = async (queryString: string, searchMode?: string, sortMode?: string) => {\r\n        if (!queryString) return\r\n\r\n        queryString = queryString.split(' ').join('+')\r\n        searchMode = searchMode || this.state.searchMode\r\n        sortMode = sortMode || this.state.sortMode\r\n\r\n        let apilink = 'https://api.github.com/search/' + searchMode + '?q=' + queryString + '&sort=stars&order=' + sortMode\r\n        let fetchData = await (await fetch(apilink)).json()\r\n\r\n        this.props.changeqstring(queryString)\r\n        this.setState({\r\n            queryString,\r\n            searchMode,\r\n            sortMode,\r\n            fetchData: fetchData.items ? fetchData.items : []\r\n        })\r\n\r\n    }\r\n\r\n    changeSearchMode = (searchMode: string) => {\r\n        const { queryString, sortMode } = this.state\r\n        if (queryString) this.handleSearch(queryString, searchMode, sortMode)\r\n        else this.setState({ searchMode })\r\n    }\r\n\r\n    changeSortingMode = (sortMode: string) => {\r\n        const { queryString, searchMode } = this.state\r\n        if (queryString) this.handleSearch(queryString, searchMode, sortMode)\r\n        else this.setState({ sortMode })\r\n    }\r\n\r\n    render() {\r\n        console.log(this.state.fetchData)\r\n\r\n        let list = this.state.searchMode === 'users' ?\r\n            <UsersList users={this.state.fetchData as UserData[]}></UsersList> :\r\n            <ReppositoriesList repos={this.state.fetchData as RepoData[]}></ReppositoriesList>\r\n\r\n        if (!this.state.queryString)\r\n            list = <></>\r\n\r\n        return (<>\r\n            <div className='search-area'>\r\n                <SearchBar handleSearch={this.handleSearch}></SearchBar>\r\n            </div>\r\n            <div className='result-area'>\r\n                <div className=\"mods\">\r\n                    <SearchModesList changeSearchMode={this.changeSearchMode}></SearchModesList>\r\n                    <SortingMode changeSortingMode={this.changeSortingMode}></SortingMode>\r\n                </div>\r\n                {list}\r\n            </div>\r\n        </>);\r\n    }\r\n}\r\n\r\n\r\ninterface SearchBarProps { handleSearch: any }\r\nfunction SearchBar(props: SearchBarProps) {\r\n    const [queryString, setSearchValue] = useState('')\r\n\r\n\r\n    return (<>\r\n        <div className=\"searchbar\">\r\n            <h1 className='searchbar-title'>Search gitHub uers and repositories</h1>\r\n            <input value={queryString || qstirngSave} type=\"text\" onChange={(e) => setSearchValue(e.target.value)} className=\"searchbar-input\" />\r\n            <button type=\"button\" onClick={() => props.handleSearch(queryString)} className=\"btn btn-primary searchbar-btn\">Search</button>\r\n        </div>\r\n    </>);\r\n}\r\n\r\n\r\ninterface SearchModeProps { changeSearchMode: any }\r\nfunction SearchModesList(props: SearchModeProps) {\r\n    const [SearchMode, setSearchMode] = useState('repositories')\r\n\r\n    useEffect(() => {\r\n        props.changeSearchMode(SearchMode)\r\n    }, [SearchMode]);\r\n\r\n    return (<>\r\n        <ul className=\"list-group list-group-horizontal\">\r\n            <li className={`\r\n                list-group-item\r\n                ${SearchMode === 'repositories' ? 'active' : ''}\r\n            `} onClick={() => setSearchMode('repositories')}>Repositories</li>\r\n            <li className={`\r\n                list-group-item\r\n                ${SearchMode === 'users' ? 'active' : ''}\r\n            `} onClick={() => setSearchMode('users')}>Users</li>\r\n        </ul>\r\n    </>)\r\n}\r\n\r\n\r\ninterface SortingModeProps { changeSortingMode: any }\r\nfunction SortingMode(props: SortingModeProps) {\r\n    const [SortingMode, setSortingMode] = useState('desc')\r\n\r\n    useEffect(() => {\r\n        props.changeSortingMode(SortingMode)\r\n    }, [SortingMode]);\r\n\r\n    return (<>\r\n        <ul className=\"list-group list-group-horizontal \">\r\n            <li className={`\r\n                list-group-item\r\n                ${SortingMode === 'desc' ? 'active' : ''}\r\n            `} onClick={() => setSortingMode('desc')}><i className=\"demo-icon icon-star\"></i></li>\r\n            <li className={`\r\n                list-group-item\r\n                ${SortingMode === 'asc' ? 'active' : ''}\r\n            `} onClick={() => setSortingMode('asc')}><i className=\"demo-icon icon-star-empty\"></i></li>\r\n        </ul>\r\n    </>)\r\n}\r\n\r\n\r\nexport default SearchScreen;\r\n","D:\\DEV_JS\\React\\gitsearch\\src\\components\\userScreen.tsx",[],["41","42"],"D:\\DEV_JS\\React\\gitsearch\\src\\components\\RepositoryComp.tsx",[],"D:\\DEV_JS\\React\\gitsearch\\src\\components\\usersComponent.tsx",[],"D:\\DEV_JS\\React\\gitsearch\\src\\components\\RepositoryScreen.tsx",["43","44"],"D:\\DEV_JS\\React\\gitsearch\\src\\components\\repositoryScreen.tsx",["45"],"import React, { FC } from 'react';\r\nimport { match } from 'react-router-dom';\r\nimport { RepoData } from '../interfaces';\r\nimport '../styles/repositoryScreen.css'\r\nimport Axios from 'axios';\r\nimport { RepoitoryProps } from '../App';\r\n\r\nexport interface RepositoryScreenProps {\r\n    match: match<RepoitoryProps>,\r\n    location: any\r\n}\r\n\r\nexport interface RepositoryScreenState {\r\n    repository?: RepoData,\r\n    repositoryCommits?: any[],\r\n}\r\n\r\nclass RepositoryScreen extends React.Component<RepositoryScreenProps, RepositoryScreenState> {\r\n    state: RepositoryScreenState = {}\r\n\r\n    componentDidMount() {\r\n        Axios.get(this.props.location.state)\r\n            .then(res => {\r\n                const repository: RepoData = res.data\r\n                let commitsurl = repository.commits_url.split('commits')\r\n                commitsurl.pop()\r\n                return Promise.all([repository, Axios.get(commitsurl.join('') + 'commits')])\r\n            })\r\n            .then(([repository, repos]) => {\r\n                this.setState({ repository, repositoryCommits: repos.data })\r\n            })\r\n            .catch(console.log)\r\n    }\r\n\r\n    render() {\r\n        const { repository, repositoryCommits } = this.state\r\n        if (!repository) return <h1 className='not-found'> Repository not found..</h1>\r\n\r\n        let commits = repositoryCommits ? repositoryCommits.map(commit => <Commit key={commit.sha} commit={commit.commit}></Commit>) : []\r\n\r\n        return (\r\n            <div className=\"repository-box\">\r\n                <div className=\"userbox\">\r\n                    <h1>\r\n                        <a target='blank' href={repository.owner.html_url}>\r\n                            <i className=\"demo-icon icon-user\"></i>\r\n                            {repository.owner.login}\r\n                        </a>\r\n                        <a target='blank' href={repository.html_url}>\r\n                            <i className=\"demo-icon icon-bookmark\"></i>\r\n                            {repository.name}\r\n                        </a>\r\n                    </h1>\r\n                    <p className='repository-description'>\r\n                        <span className=\"title\">about\r\n                        <i className=\"demo-icon icon-search\"></i>\r\n                        </span>\r\n                        {repository.description}\r\n                    </p>\r\n                </div>\r\n                <div className=\"commits\">\r\n                    <p className=\"title\">commits<i className=\"demo-icon icon-flow-branch\"></i> </p>\r\n                    {commits}\r\n                </div>\r\n            </div>\r\n        );\r\n    }\r\n}\r\n\r\n\r\ninterface Commit {\r\n    message: string,\r\n    committer: {\r\n        name: string,\r\n        email: string,\r\n        date: string,\r\n    }\r\n}\r\n\r\nexport const Commit: FC<{ commit: Commit }> = ({ commit }) => {\r\n    let date = new Date(commit.committer.date).toLocaleDateString()\r\n    return (<div className='commit'>\r\n        <h1 className='committer-name'><span className=\"label\">Commiter:</span> {commit.committer.name}</h1>\r\n        <p className='committer-email'><span className=\"label\">email:</span> {commit.committer.email}</p>\r\n        <p className=\"commit-message\"><span className=\"label\">message:</span> {commit.message}</p>\r\n        <p className=\"commit-date\"><span className=\"label\">date:</span> {date}</p>\r\n    </div>)\r\n}\r\n\r\nexport default RepositoryScreen;\r\n",{"ruleId":"46","severity":1,"message":"47","line":1,"column":38,"nodeType":"48","messageId":"49","endLine":1,"endColumn":40},{"ruleId":"46","severity":1,"message":"50","line":1,"column":42,"nodeType":"48","messageId":"49","endLine":1,"endColumn":67},{"ruleId":"51","severity":1,"message":"52","line":114,"column":8,"nodeType":"53","endLine":114,"endColumn":20,"suggestions":"54"},{"ruleId":"51","severity":1,"message":"52","line":137,"column":8,"nodeType":"53","endLine":137,"endColumn":21,"suggestions":"55"},{"ruleId":"56","replacedBy":"57"},{"ruleId":"58","replacedBy":"59"},{"ruleId":"46","severity":1,"message":"60","line":3,"column":20,"nodeType":"48","messageId":"49","endLine":3,"endColumn":28},{"ruleId":"61","severity":1,"message":"62","line":66,"column":14,"nodeType":"48","messageId":"63","endLine":66,"endColumn":44},{"ruleId":"61","severity":1,"message":"62","line":80,"column":14,"nodeType":"48","messageId":"63","endLine":80,"endColumn":44},"@typescript-eslint/no-unused-vars","'FC' is defined but never used.","Identifier","unusedVar","'ReducerStateWithoutAction' is defined but never used.","react-hooks/exhaustive-deps","React Hook useEffect has a missing dependency: 'props'. Either include it or remove the dependency array. However, 'props' will change when *any* prop changes, so the preferred fix is to destructure the 'props' object outside of the useEffect call and refer to those specific props inside useEffect.","ArrayExpression",["64"],["65"],"no-native-reassign",["66"],"no-negated-in-lhs",["67"],"'UserData' is defined but never used.","@typescript-eslint/no-redeclare","'Commit' is already defined.","redeclared",{"desc":"68","fix":"69"},{"desc":"70","fix":"71"},"no-global-assign","no-unsafe-negation","Update the dependencies array to be: [SearchMode, props]",{"range":"72","text":"73"},"Update the dependencies array to be: [SortingMode, props]",{"range":"74","text":"75"},[3885,3897],"[SearchMode, props]",[4649,4662],"[SortingMode, props]"]